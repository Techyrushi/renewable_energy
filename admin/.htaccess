<IfModule mod_authz_core.c>
  <FilesMatch "\.html$">
    Require all denied
  </FilesMatch>
</IfModule>

<IfModule mod_access_compat.c>
  <FilesMatch "\.html$">
    Order allow,deny
    Deny from all
  </FilesMatch>
</IfModule>

<IfModule mod_rewrite.c>
RewriteEngine On

RewriteCond %{REQUEST_METHOD} !=POST
RewriteCond %{THE_REQUEST} \s/[^?\s]*/admin/([a-z0-9_-]+)\.php[?\s] [NC]
RewriteRule ^%1\.php$ %1 [R=301,L]

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^$ index.php [L]

RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+?)/?$ $1.php [L]
</IfModule>
