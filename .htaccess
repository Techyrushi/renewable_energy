RewriteEngine On

ErrorDocument 404 /404.php

RewriteRule ^robots\.txt$ robots.php [L]
RewriteRule ^sitemap\.xml$ sitemap.php [L]

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^admin/login/?$ admin/login.php [L]

RewriteRule ^about/?$ about-us.php [L]
RewriteRule ^services/?$ services.php [L]
RewriteRule ^services/solar-installation/?$ service-details.php?service=solar-installation [L,QSA]
RewriteRule ^services/operations-maintenance/?$ service-details.php?service=operations-maintenance [L,QSA]
RewriteRule ^services/energy-consulting/?$ service-details.php?service=energy-consulting [L,QSA]
RewriteRule ^services/open-access-ppa/?$ service-details.php?service=open-access-ppa [L,QSA]
RewriteRule ^services/([a-z0-9-]+)/?$ service-details.php?service=$1 [L,QSA]
RewriteRule ^products/?$ products.php [L]
RewriteRule ^projects/?$ projects.php [L]
RewriteRule ^why-us/?$ why-us.php [L]
RewriteRule ^blog/?$ blog.php [L]
RewriteRule ^blog/([a-z0-9-]+)/?$ blog-details.php?post=$1 [L,QSA]
RewriteRule ^projects/([a-z0-9-]+)/?$ projects-details.php?project=$1 [L,QSA]
RewriteRule ^products/([a-z0-9-]+)/?$ product-details.php?product=$1 [L,QSA]
RewriteRule ^contact/?$ contact-us.php [L]
RewriteRule ^privacy-policy/?$ privacy-policy.php [L]
RewriteRule ^terms-of-use/?$ terms.php [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . 404.php [L]

<IfModule mod_deflate.c>
	AddOutputFilterByType DEFLATE text/plain text/html text/xml text/css text/javascript application/javascript application/json application/xml application/xhtml+xml image/svg+xml
	Header always set Vary "Accept-Encoding"
</IfModule>

<IfModule mod_expires.c>
	ExpiresActive On
	ExpiresDefault "access plus 7 days"
	ExpiresByType text/css "access plus 30 days"
	ExpiresByType application/javascript "access plus 30 days"
	ExpiresByType text/javascript "access plus 30 days"
	ExpiresByType image/jpg "access plus 180 days"
	ExpiresByType image/jpeg "access plus 180 days"
	ExpiresByType image/png "access plus 180 days"
	ExpiresByType image/gif "access plus 180 days"
	ExpiresByType image/webp "access plus 180 days"
	ExpiresByType image/svg+xml "access plus 180 days"
	ExpiresByType font/woff2 "access plus 180 days"
	ExpiresByType font/woff "access plus 180 days"
</IfModule>

<IfModule mod_headers.c>
	<FilesMatch "\.(css|js|png|jpg|jpeg|gif|webp|svg|woff|woff2)$">
		Header set Cache-Control "public, max-age=15552000, immutable"
	</FilesMatch>
</IfModule>
