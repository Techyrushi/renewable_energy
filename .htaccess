RewriteEngine On

ErrorDocument 404 /404.php

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^about/?$ about-us.php [L]
RewriteRule ^services/?$ services.php [L]
RewriteRule ^services/solar-installation/?$ solar-installation.php [L]
RewriteRule ^services/operations-maintenance/?$ operations-maintenance.php [L]
RewriteRule ^services/energy-consulting/?$ energy-consulting.php [L]
RewriteRule ^services/open-access-ppa/?$ open-access-ppa.php [L]
RewriteRule ^products/?$ products.php [L]
RewriteRule ^projects/?$ projects.php [L]
RewriteRule ^why-us/?$ why-us.php [L]
RewriteRule ^blog/?$ blog.php [L]
RewriteRule ^contact/?$ contact-us.php [L]
RewriteRule ^privacy-policy/?$ privacy-policy.php [L]
RewriteRule ^terms-of-use/?$ terms.php [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . 404.php [L]
